{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "Adtool",
  "colors": {
    "primary": "#F64900",
    "light": "#e6e6e6",
    "dark": "#171717"
  },
  "favicon": "/logo/adtool-favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Help Center",
        "groups": [
          {
            "group": "Getting started",
            "icon": "circle-play",
            "expanded": true,
            "pages": [
              "Getting-Started/full-walkthrough"
            ]
          },
          {
            "group": "Help articles",
            "icon": "book-open",
            "pages": [
              {
                "group": "Ad types",
                "icon": "arrow-alt-circle-right",
                "expanded": false,
                "pages": [
                  "Launch/launching-single-image-or-video",
                  "Launch/launching-carousel-ads",
                  "Launch/partnership-ads",
                  "Launch/multi-language-ads",
                  "Launch/launching-flexible-ads",
                  "Launch/launch-organic-posts",
                  "Launch/launch-organic-posts"
                ]
              },
              {
                "group": "Launch",
                "icon": "rocket",
                "expanded": false,
                "pages": [
                  "Launch/dublicate-campaigns",
                  "Launch/dublicate-ad-sets",
                  "Launch/customize-ads-individually",
                  "Launch/bulk-edit-ad-names",
                  "Launch/work-effectively-with-relaunch-function",
                  "Launch/adjust-additional-settings",
                  "Launch/save-as-draft",
                  "Launch/schedule-ads",
                  "Launch/preview-link"
                ]
              },
              {
                "group": "Creative Grouping",
                "icon": "layer-group",
                "pages": [
                  "Launch/grouping-creatives",
                  "Launch/grouping-with-3-placement-groups",
                  "Launch/carousel-grouping",
                  "Creatives/auto-grouping-guide"
                ]
              },
              {
                "group": "Creatives",
                "icon": "image",
                "expanded": false,
                "pages": [
                  "Creatives/upload-creatives",
                  "Creatives/set-custom-thumbnails",
                  "Creatives/tagging-your-creatives"
                ]
              },
              {
                "group": "Settings",
                "icon": "cog",
                "expanded": false,
                "pages": [
                  "Settings/creative-enhancements",
                  "Settings/UTM-parameters",
                  "Settings/manage-connections",
                  "Settings/naming-convention",
                  "Settings/ad-defaults"
                ]
              },
              {
                "group": "Troubleshoot",
                "icon": "bug",
                "expanded": false,
                "pages": [
                  "Troubleshoot/cant-see-my-FB-or-IG-page",
                  "Troubleshoot/cant-see-ads",
                  "Troubleshoot/reconnect-meta"
                ]
              }
            ]
          }
        ]
      },
      {
        "tab": "Changelog",
        "pages": [
          "updates"
        ],
        "hidden": true
      }
    ]
  },
  "logo": {
    "light": "/logo/adtool-light.svg",
    "dark": "/logo/adtool-dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Get support from livechat",
        "href": "https://adtool.io/?chat=open"
      }
    ],
    "primary": {
      "type": "button",
      "icon": "arrow-up-right",
      "label": "Back to Adtool.io",
      "href": "https://adtool.io/launch"
    }
  },
  "appearance": {
    "default": "system"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "interaction": {
    "drilldown": false
  },
  "description": "Guides for using Adtool to upload creatives, organize content, launch Meta ads, manage settings, and troubleshoot common issues."
}
